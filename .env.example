# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# For Development (SQLite)
# DATABASE_URL=sqlite:///app.db

# For Production (PostgreSQL on Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/x_twitter_clone

# Mail Configuration (Gmail SMTP Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@x-twitter-clone.com

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Security
PREFERRED_URL_SCHEME=https

# Optional: AWS S3 for file uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
